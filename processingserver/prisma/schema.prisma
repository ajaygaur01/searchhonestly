// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

enum DataSource {
  REDDIT
  YOUTUBE
  BLOG
}

enum DataStatus {
  UNPROCESSED
  PROCESSING
  PROCESSED
  FAILED
}

model SearchQuery {
  id          String   @id @default(uuid())
  query       String   @unique  // for deduplication/cache lookup
  createdAt   DateTime @default(now())

  rawData     RawData[]
  result      ProcessedResult?
}

model RawData {
  id          String     @id @default(uuid())
  queryId     String
  source      DataSource
  status      DataStatus @default(UNPROCESSED)
  payload     Json
  createdAt   DateTime   @default(now())

  query       SearchQuery @relation(fields: [queryId], references: [id])
}

model ProcessedResult {
  id          String      @id @default(uuid())
  queryId     String      @unique
  summary     String      // Groq's filtered/summarized output
  rawOutput   Json?       // full Groq response if needed
  createdAt   DateTime    @default(now())

  query       SearchQuery @relation(fields: [queryId], references: [id])
}