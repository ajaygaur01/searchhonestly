generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

model RawScrape {
  id          String   @id @default(uuid())
  source      Source   
  externalId  String   @unique 
  rawContent  Json     
  status      Status   @default(PENDING) 
  createdAt   DateTime @default(now())
  processed   ProcessedInsight?

  @@index([source, status])
}

model ProcessedInsight {
  id             String    @id @default(uuid())
  rawScrapeId    String    @unique
  rawScrape      RawScrape @relation(fields: [rawScrapeId], references: [id], onDelete: Cascade)
  
  title          String
  summary        String    @db.Text
  keyPoints      Json      
  relevanceScore Int       
  sourceUrl      String?     
  createdAt      DateTime  @default(now())
}
enum Source {
  REDDIT
  YOUTUBE
  SUBSTACK
  BLOG
}

enum Status {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}